# =============================================================================
# Roo Code 모드별 권장 모델 설정
# =============================================================================
# 사용법: VS Code settings.json에 roo-settings.json 내용을 복사하거나,
#         이 파일을 참고하여 Roo Code UI에서 모드별 모델을 직접 설정하세요.
#
# 프록시 Base URL: http://localhost:4000/api/v1
# API Key:        sk-dummy (프록시가 실제 인증 처리)
# =============================================================================

# ── Code 모드 (💻 코드 작성·수정·리팩토링·버그 수정) ──────────────────────────
# 선택 모델: claude-sonnet-4-6
# 이유: Claude 계열은 코드 품질·문법 정확도가 최상위권이며,
#       Sonnet은 Opus 대비 응답 속도가 빠르면서도 코딩 능력이 충분합니다.
#       반복적인 코드 편집 작업에서 속도와 품질의 최적 균형점입니다.
ROO_MODEL_CODE=claude-sonnet-4-6

# ── Architect 모드 (🏗️ 시스템 설계·기술 명세·아키텍처 계획) ─────────────────
# 선택 모델: claude-opus-4-6
# 이유: 아키텍처 설계는 응답 속도보다 추론 깊이와 품질이 중요합니다.
#       Opus는 Claude 계열 최고 성능 모델로, 복잡한 시스템 간 의존성 분석,
#       트레이드오프 평가, 장기적 설계 결정에 가장 적합합니다.
ROO_MODEL_ARCHITECT=claude-opus-4-6

# ── Ask 모드 (❓ 개념 설명·문서화·기술 질문 답변) ────────────────────────────
# 선택 모델: claude-sonnet-4-6
# 이유: 질문 답변은 빠른 응답과 폭넓은 지식이 핵심입니다.
#       Sonnet은 다양한 기술 도메인에 걸쳐 정확하고 명확한 설명을 제공하며,
#       Haiku보다 답변 품질이 높고 Opus보다 응답이 빠릅니다.
ROO_MODEL_ASK=claude-sonnet-4-6

# ── Debug 모드 (🪲 디버깅·오류 분석·로그 분석) ───────────────────────────────
# 선택 모델: claude-opus-4-6
# 이유: 디버깅은 스택 트레이스 해석, 코드 흐름 추적, 근본 원인 분석 등
#       정밀한 추론이 필요합니다. Opus의 높은 추론 능력이 복잡한 버그
#       재현 경로 파악과 정확한 수정 방향 제시에 결정적 차이를 만듭니다.
ROO_MODEL_DEBUG=claude-opus-4-6

# ── Orchestrator 모드 (🪃 복잡한 워크플로우 조율·멀티 에이전트 관리) ─────────
# 선택 모델: gpt-5.4-xhigh
# 이유: Orchestrator는 전체 작업을 분해하고 하위 에이전트를 지시하는
#       최상위 계획자 역할입니다. gpt-5.4-xhigh는 연구 수준의 심층 분석과
#       대규모 코드 설계 능력을 갖추고 있어, 복잡한 멀티스텝 워크플로우
#       계획 수립에 Claude Opus와 함께 최고 수준의 성능을 발휘합니다.
#       Claude와 다른 모델 계열을 사용함으로써 관점 다양성도 확보됩니다.
ROO_MODEL_ORCHESTRATOR=gpt-5.4-xhigh

# =============================================================================
# 대안 모델 참고 (필요 시 위 값을 교체하여 사용)
# =============================================================================
# ROO_MODEL_CODE_ALT=gpt-5.4-high          # GPT 계열 코딩 대안
# ROO_MODEL_ARCHITECT_ALT=gpt-5.4-xhigh    # GPT 계열 설계 대안
# ROO_MODEL_ASK_ALT=claude-haiku           # 빠른 응답 우선 시
# ROO_MODEL_ASK_ALT2=perplexity-sonar-pro  # 최신 웹 정보 검색 필요 시
# ROO_MODEL_DEBUG_ALT=gpt-5.4-high         # GPT 계열 디버깅 대안
# ROO_MODEL_ORCHESTRATOR_ALT=claude-opus-4-6  # Claude 계열 오케스트레이터 대안
